{
  "server": {
    "addr": "127.0.0.1:8080",
    "max_body_bytes": 1048576,
    "read_timeout": "5s",
    "write_timeout": "30s",
    "idle_timeout": "2m",
    "shutdown_timeout": "10s"
  },
  "openai": {
    "api_key_env": "OPENAI_API_KEY"
  },
  "backends": [
    {
      "id": "fast",
      "model": "gpt-4.1-nano",
      "max_completion_tokens": 512
    },
    {
      "id": "balanced",
      "model": "gpt-4.1-mini",
      "max_completion_tokens": 768
    },
    {
      "id": "strong",
      "model": "gpt-4.1",
      "max_completion_tokens": 1024
    }
  ],
  "routes": [
    {
      "name": "simple-chat",
      "match": {
        "task_types": ["chat"]
      },
      "candidates": [
        {"backend": "fast"},
        {"backend": "balanced"}
      ]
    },
    {
      "name": "coding",
      "match": {
        "task_types": ["coding"]
      },
      "candidates": [
        {"backend": "balanced"},
        {"backend": "strong"}
      ]
    },
    {
      "name": "reasoning",
      "match": {
        "task_types": ["reasoning"]
      },
      "candidates": [
        {"backend": "balanced"},
        {"backend": "strong"}
      ]
    },
    {
      "name": "default",
      "candidates": [
        {"backend": "fast"},
        {"backend": "balanced"},
        {"backend": "strong"}
      ]
    }
  ],
  "pricing": {
    "models": {
      "gpt-4.1-nano": {
        "input_cost_per_token": 0.0000001,
        "output_cost_per_token": 0.0000004
      },
      "gpt-4.1-mini": {
        "input_cost_per_token": 0.0000004,
        "output_cost_per_token": 0.0000016
      },
      "gpt-4.1": {
        "input_cost_per_token": 0.000002,
        "output_cost_per_token": 0.000008
      }
    }
  },
  "router": {
    "type": "bandit",
    "seed": 7
  },
  "data_plane": {
    "filters": ["tenant", "health", "circuit", "concurrency"],
    "circuit": {
      "failure_threshold": 3,
      "recovery_after": "2s",
      "half_open_max": 1
    },
    "concurrency": {
      "initial_limit": 8,
      "min_limit": 1,
      "max_limit": 64,
      "target_latency_ms": 1200
    }
  },
  "learning": {
    "enabled": true,
    "tau": "10m",
    "prior_precision": 1.0,
    "queue_size": 1024,
    "persistence": {
      "enabled": true,
      "path": ".augur/request-aware-state.json",
      "save_every": 1
    },
    "judge": {
      "enabled": false,
      "model": "your-judge-model-id",
      "seed": 11
    }
  },
  "policy": {
    "id": "request-aware-v1",
    "constraints": {
      "max_p95_ms": 2400,
      "min_quality": 0.85,
      "max_error_rate": 0.05,
      "quality_gate": "mean"
    },
    "objective": {
      "type": "blend",
      "latency_weight": 0.1,
      "cost_weight": 1.0
    },
    "exploration": {
      "cold_start_budget": 0.05,
      "judge_sample_rate": 0.1,
      "uncertainty_sampling": true
    },
    "on_infeasible": "best_effort"
  },
  "budgets": {
    "latency_budget_ms": 1200,
    "cost_budget_usd": 0.02,
    "max_completion_tokens": 512,
    "temperature": 0.2
  }
}
